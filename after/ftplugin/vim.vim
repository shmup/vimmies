" disable gq formatting since it breaks vimscript code structure
setlocal formatprg=
setlocal formatoptions=croql
setlocal textwidth=0
setlocal comments=:\"
setlocal commentstring=\"\ %s

" better indentation settings for vimscript
setlocal shiftwidth=2
setlocal tabstop=2
setlocal softtabstop=2
setlocal expandtab
